DATABASE_URL="postgresql://USER:PASSWORD@HOST/neondb?sslmode=require"
JWT_SECRET="replace-with-a-minimum-32-character-secret"
JWT_EXPIRES_IN="7d"
GEMINI_API_KEY="replace-with-google-ai-studio-key"
GEMINI_MODEL="gemini-2.5-flash"
UNSPLASH_ACCESS_KEY="replace-with-unsplash-access-key"
OPENTRIPMAP_API_KEY="replace-with-opentripmap-api-key"
OPENWEATHER_API_KEY="replace-with-openweather-api-key"
GEODB_API_KEY="replace-with-rapidapi-geodb-key"
CLOUDINARY_CLOUD_NAME="replace-with-cloud-name"
CLOUDINARY_API_KEY="replace-with-api-key"
CLOUDINARY_API_SECRET="replace-with-api-secret"
RESEND_API_KEY="replace-with-resend-key"
RESEND_FROM_EMAIL="Traveloop <no-reply@your-domain.com>"
TWILIO_ACCOUNT_SID="replace-with-twilio-account-sid"
TWILIO_AUTH_TOKEN="replace-with-twilio-auth-token"
TWILIO_SMS_FROM="+15551234567"
TWILIO_WHATSAPP_FROM="+15551234567"
FRONTEND_URL="http://localhost:5173"
# Optional comma-separated extra frontend origins for previews/custom domains.
# Example: "https://traveloop.vercel.app,https://preview.traveloop.app"
CORS_ALLOWED_ORIGINS=""
NODE_ENV="development"
PORT="3000"
LOG_LEVEL="debug"
