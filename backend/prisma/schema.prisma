generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              String             @id @default(uuid()) @db.Uuid
  email           String             @unique @db.VarChar(255)
  passwordHash    String             @map("password_hash") @db.VarChar(255)
  name            String             @db.VarChar(100)
  username        String?            @unique @db.VarChar(40)
  phoneNumber     String?            @map("phone_number") @db.VarChar(20)
  emailVerifiedAt DateTime?          @map("email_verified_at") @db.Timestamp(6)
  phoneVerifiedAt DateTime?          @map("phone_verified_at") @db.Timestamp(6)
  avatarUrl       String?            @map("avatar_url") @db.Text
  bio             String?            @db.Text
  travelerProfile String             @default("solo") @map("traveler_profile") @db.VarChar(20)
  preferredBudgetMin Decimal?        @map("preferred_budget_min") @db.Decimal(10, 2)
  preferredBudgetMax Decimal?        @map("preferred_budget_max") @db.Decimal(10, 2)
  travelStyles    Json?              @map("travel_styles")
  travelPreferences Json?            @map("travel_preferences")
  language        String             @default("en") @db.VarChar(10)
  isAdmin         Boolean            @default(false) @map("is_admin")
  isDeleted       Boolean            @default(false) @map("is_deleted")
  deletedAt       DateTime?          @map("deleted_at") @db.Timestamp(6)
  otpHash         String?            @map("otp_hash") @db.VarChar(255)
  otpExpiresAt    DateTime?          @map("otp_expires_at") @db.Timestamp(6)
  deleteOtpHash   String?            @map("delete_otp_hash") @db.VarChar(255)
  deleteOtpExpiresAt DateTime?       @map("delete_otp_expires_at") @db.Timestamp(6)
  emailVerificationOtpHash String?   @map("email_verification_otp_hash") @db.VarChar(255)
  emailVerificationOtpExpiresAt DateTime? @map("email_verification_otp_expires_at") @db.Timestamp(6)
  phoneVerificationOtpHash String?   @map("phone_verification_otp_hash") @db.VarChar(255)
  phoneVerificationOtpExpiresAt DateTime? @map("phone_verification_otp_expires_at") @db.Timestamp(6)
  createdAt       DateTime           @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime           @updatedAt @map("updated_at") @db.Timestamp(6)
  trips           Trip[]
  mediaUploads    MediaUpload[]
  passwordOtps    PasswordResetOtp[]
  communityPosts  CommunityPost[]      @relation("CommunityPostAuthor")
  communityComments CommunityComment[] @relation("CommunityCommentAuthor")
  communityLikes  CommunityLike[]
  communityBookmarks CommunityBookmark[]
  communityPlaceMessages CommunityPlaceMessage[] @relation("CommunityPlaceMessageAuthor")

  @@index([email], map: "idx_users_email")
  @@index([isDeleted], map: "idx_users_is_deleted")
  @@map("users")
}

model Trip {
  id            String        @id @default(uuid()) @db.Uuid
  userId        String        @map("user_id") @db.Uuid
  title         String        @db.VarChar(255)
  description   String?       @db.Text
  coverPhotoUrl String?       @map("cover_photo_url") @db.Text
  startDate     DateTime      @map("start_date") @db.Date
  endDate       DateTime      @map("end_date") @db.Date
  tripType      String        @map("trip_type") @db.VarChar(30)
  budgetCapUsd  Decimal?      @map("budget_cap_usd") @db.Decimal(10, 2)
  vibe          String?       @db.VarChar(20)
  isPublic      Boolean       @default(false) @map("is_public")
  publicSlug    String?       @unique @map("public_slug") @db.VarChar(100)
  status        String        @default("planning") @db.VarChar(20)
  deletedAt     DateTime?     @map("deleted_at") @db.Timestamp(6)
  createdAt     DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt     DateTime      @updatedAt @map("updated_at") @db.Timestamp(6)
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  stops         Stop[]
  packingItems  PackingItem[]
  tripNotes     TripNote[]
  mediaUploads  MediaUpload[]
  communityPosts CommunityPost[]

  @@index([userId], map: "idx_trips_user_id")
  @@index([publicSlug], map: "idx_trips_public_slug")
  @@index([status], map: "idx_trips_status")
  @@map("trips")
}

model City {
  id            String                 @id @default(uuid()) @db.Uuid
  name          String                 @db.VarChar(100)
  state         String?                @db.VarChar(100)
  country       String                 @db.VarChar(100)
  countryCode   String                 @map("country_code") @db.Char(2)
  latitude      Decimal                @db.Decimal(9, 6)
  longitude     Decimal                @db.Decimal(9, 6)
  costIndex     String?                @map("cost_index") @db.VarChar(10)
  areaType      String?                @map("area_type") @db.VarChar(20)
  bestSeason    String?                @map("best_season") @db.VarChar(100)
  isRegionalGem Boolean                @default(false) @map("is_regional_gem")
  thumbnailUrl  String?                @map("thumbnail_url") @db.Text
  region        String?                @db.VarChar(50)
  searchVector  Unsupported("tsvector")? @map("search_vector")
  stops         Stop[]
  activities    Activity[]
  destinationEnrichment DestinationEnrichment?

  @@index([countryCode], map: "idx_cities_country_code")
  @@map("cities")
}

model DestinationEnrichment {
  id             String   @id @default(uuid()) @db.Uuid
  cityId         String   @unique @map("city_id") @db.Uuid
  description    String?  @db.Text
  wikiUrl        String?  @map("wiki_url") @db.Text
  heroImageUrl   String?  @map("hero_image_url") @db.Text
  gallery        Json?
  attractions    Json?
  weather        Json?
  budgetEstimate Json?    @map("budget_estimate")
  aiSummary      String?  @map("ai_summary") @db.Text
  sourceMetadata Json?    @map("source_metadata")
  refreshedAt    DateTime @default(now()) @map("refreshed_at") @db.Timestamp(6)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamp(6)
  city           City     @relation(fields: [cityId], references: [id], onDelete: Cascade)

  @@index([refreshedAt], map: "idx_destination_enrichments_refreshed_at")
  @@map("destination_enrichments")
}

model Stop {
  id                String         @id @default(uuid()) @db.Uuid
  tripId            String         @map("trip_id") @db.Uuid
  cityId            String         @map("city_id") @db.Uuid
  orderIndex        Int            @map("order_index")
  arrivalDate       DateTime       @map("arrival_date") @db.Date
  departureDate     DateTime       @map("departure_date") @db.Date
  notes             String?        @db.Text
  accommodationName String?        @map("accommodation_name") @db.VarChar(255)
  accommodationCost Decimal?       @map("accommodation_cost") @db.Decimal(8, 2)
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt         DateTime       @updatedAt @map("updated_at") @db.Timestamp(6)
  trip              Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  city              City           @relation(fields: [cityId], references: [id])
  stopActivities    StopActivity[]
  tripNotes         TripNote[]
  mediaUploads      MediaUpload[]

  @@index([tripId], map: "idx_stops_trip_id")
  @@index([cityId], map: "idx_stops_city_id")
  @@map("stops")
}

model Activity {
  id               String         @id @default(uuid()) @db.Uuid
  cityId           String         @map("city_id") @db.Uuid
  name             String         @db.VarChar(255)
  category         String         @db.VarChar(50)
  tripTypeTags     Json           @map("trip_type_tags")
  estimatedCostUsd Decimal        @map("estimated_cost_usd") @db.Decimal(8, 2)
  durationHours    Decimal        @map("duration_hours") @db.Decimal(4, 1)
  description      String?        @db.Text
  imageUrl         String?        @map("image_url") @db.Text
  city             City           @relation(fields: [cityId], references: [id])
  stopActivities   StopActivity[]

  @@index([cityId], map: "idx_activities_city_id")
  @@map("activities")
}

model StopActivity {
  id            String    @id @default(uuid()) @db.Uuid
  stopId        String    @map("stop_id") @db.Uuid
  activityId    String    @map("activity_id") @db.Uuid
  scheduledTime DateTime? @map("scheduled_time") @db.Time(6)
  actualCostUsd Decimal?  @map("actual_cost_usd") @db.Decimal(8, 2)
  isCompleted   Boolean   @default(false) @map("is_completed")
  stop          Stop      @relation(fields: [stopId], references: [id], onDelete: Cascade)
  activity      Activity  @relation(fields: [activityId], references: [id])

  @@index([stopId], map: "idx_sa_stop_id")
  @@map("stop_activities")
}

model PackingItem {
  id          String  @id @default(uuid()) @db.Uuid
  tripId      String  @map("trip_id") @db.Uuid
  name        String  @db.VarChar(255)
  category    String  @db.VarChar(50)
  isPacked    Boolean @default(false) @map("is_packed")
  aiSuggested Boolean @default(false) @map("ai_suggested")
  trip        Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([tripId], map: "idx_packing_trip_id")
  @@map("packing_items")
}

model TripNote {
  id          String   @id @default(uuid()) @db.Uuid
  tripId      String   @map("trip_id") @db.Uuid
  stopId      String?  @map("stop_id") @db.Uuid
  title       String   @db.VarChar(255)
  content     String   @db.Text
  noteType    String   @map("note_type") @db.VarChar(20)
  isImportant Boolean  @default(false) @map("is_important")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamp(6)
  trip        Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  stop        Stop?    @relation(fields: [stopId], references: [id], onDelete: SetNull)

  @@index([tripId], map: "idx_notes_trip_id")
  @@map("trip_notes")
}

model MediaUpload {
  id            String   @id @default(uuid()) @db.Uuid
  tripId        String   @map("trip_id") @db.Uuid
  stopId        String?  @map("stop_id") @db.Uuid
  userId        String   @map("user_id") @db.Uuid
  mediaType     String   @map("media_type") @db.VarChar(10)
  cloudinaryUrl String   @map("cloudinary_url") @db.Text
  cloudinaryId  String   @map("cloudinary_id") @db.VarChar(255)
  caption       String?  @db.Text
  documentType  String?  @map("document_type") @db.VarChar(40)
  fileName      String?  @map("file_name") @db.VarChar(255)
  fileSizeBytes Int?     @map("file_size_bytes")
  mimeType      String?  @map("mime_type") @db.VarChar(120)
  expiresAt     DateTime? @map("expires_at") @db.Date
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  trip          Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  stop          Stop?    @relation(fields: [stopId], references: [id], onDelete: SetNull)
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tripId], map: "idx_media_trip_id")
  @@map("media_uploads")
}

model PasswordResetOtp {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  otpHash   String   @map("otp_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamp(6)
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "idx_password_otps_user_id")
  @@map("password_reset_otps")
}

model CommunityPost {
  id              String              @id @default(uuid()) @db.Uuid
  userId          String              @map("user_id") @db.Uuid
  tripId          String?             @map("trip_id") @db.Uuid
  title           String              @db.VarChar(180)
  content         String              @db.Text
  heroImageUrl    String?             @map("hero_image_url") @db.Text
  destinationName String?             @map("destination_name") @db.VarChar(120)
  budgetInr       Decimal?            @map("budget_inr") @db.Decimal(10, 2)
  isPublished     Boolean             @default(true) @map("is_published")
  createdAt       DateTime            @default(now()) @map("created_at") @db.Timestamp(6)
  updatedAt       DateTime            @updatedAt @map("updated_at") @db.Timestamp(6)
  user            User                @relation("CommunityPostAuthor", fields: [userId], references: [id], onDelete: Cascade)
  trip            Trip?               @relation(fields: [tripId], references: [id], onDelete: SetNull)
  comments        CommunityComment[]
  likes           CommunityLike[]
  bookmarks       CommunityBookmark[]

  @@index([createdAt], map: "idx_community_posts_created_at")
  @@index([destinationName], map: "idx_community_posts_destination")
  @@map("community_posts")
}

model CommunityComment {
  id        String        @id @default(uuid()) @db.Uuid
  postId    String        @map("post_id") @db.Uuid
  userId    String        @map("user_id") @db.Uuid
  body      String        @db.Text
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation("CommunityCommentAuthor", fields: [userId], references: [id], onDelete: Cascade)

  @@index([postId], map: "idx_community_comments_post_id")
  @@map("community_comments")
}

model CommunityLike {
  id        String        @id @default(uuid()) @db.Uuid
  postId    String        @map("post_id") @db.Uuid
  userId    String        @map("user_id") @db.Uuid
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId], map: "uq_community_like_post_user")
  @@index([postId], map: "idx_community_likes_post_id")
  @@map("community_likes")
}

model CommunityBookmark {
  id        String        @id @default(uuid()) @db.Uuid
  postId    String        @map("post_id") @db.Uuid
  userId    String        @map("user_id") @db.Uuid
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamp(6)
  post      CommunityPost @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId], map: "uq_community_bookmark_post_user")
  @@index([postId], map: "idx_community_bookmarks_post_id")
  @@map("community_bookmarks")
}

model CommunityPlaceMessage {
  id              String   @id @default(uuid()) @db.Uuid
  userId          String?  @map("user_id") @db.Uuid
  cityId          String?  @map("city_id") @db.Uuid
  destinationName String   @map("destination_name") @db.VarChar(120)
  authorAlias     String?  @map("author_alias") @db.VarChar(80)
  isSystem        Boolean  @default(false) @map("is_system")
  body            String   @db.Text
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamp(6)
  user            User?    @relation("CommunityPlaceMessageAuthor", fields: [userId], references: [id], onDelete: Cascade)

  @@index([cityId, createdAt], map: "idx_place_messages_city_created")
  @@index([destinationName, createdAt], map: "idx_place_messages_destination_created")
  @@map("community_place_messages")
}
