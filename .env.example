# Backend origin (no trailing slash) — playbook §1.7 / §3.3
VITE_API_URL=http://localhost:3000

# Public Cloudinary cloud name for upload widget (never secrets in VITE_*)
# VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
# Unsigned upload preset for public profile-photo uploads during signup
# VITE_CLOUDINARY_UPLOAD_PRESET=traveloop_unsigned

# Dev-only: serve UI against MSW mocks when backend is offline — playbook §5.3
# VITE_USE_MSW=false

# Google AdSense — optional; enables live ads on /trips/new sidebar
# https://www.google.com/adsense/ → Sites → Ads → By ad unit
# VITE_ADSENSE_CLIENT=ca-pub-xxxxxxxxxxxxxxxx
# VITE_ADSENSE_CREATE_TRIP_SLOT=1234567890
# Optional: auto (responsive display, default) or autorelaxed (Multiplex unit in AdSense)
# VITE_ADSENSE_CREATE_TRIP_FORMAT=auto
